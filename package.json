{
  "name": "tms_api",
  "version": "1.0.0",
  "description": "REST API for themindspace app",
  "main": "dist/app.js",
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": ".ts,.js",
    "exec": "npx ts-node ./src/index.ts"
  },
  "scripts": {
    "sync-db": "npx ts-node ./src/scripts/sync-prod-to-test.ts",
    "generate-docs": "npx ts-node ./src/scripts/generate-docs.ts",
    "test": "jest --runInBand --changedSince=master",
    "coverage": "jest --runInBand --coverage",
    "seed": "npx ts-node ./src/seed/seed.ts",
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "debug": "node --inspect-brk -r ts-node/register src/app.ts",
    "sync-db": "npx ts-node ./src/scripts/sync-prod-to-test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omar-tolan/tms_api.git"
  },
  "author": "Omar Tolan",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/omar-tolan/tms_api/issues"
  },
  "homepage": "https://github.com/omar-tolan/tms_api#readme",
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "^13.4.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.12.1",
    "nodemailer": "^7.0.3",
    "resend": "^6.0.2",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0"
  }
}
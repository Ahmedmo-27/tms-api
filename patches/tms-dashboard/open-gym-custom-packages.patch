+export type OpenGymRenewalPeriod =
+  | "WEEKLY"
+  | "BIWEEKLY"
+  | "TRIWEEKLY"
+  | "MONTHLY"
+  | "BIMONTHLY"
+  | "TRIMONTHLY";
+
+export const OPEN_GYM_RENEWAL_DAYS: Record<OpenGymRenewalPeriod, number> = {
+  WEEKLY: 7,
+  BIWEEKLY: 14,
+  TRIWEEKLY: 21,
+  MONTHLY: 30,
+  BIMONTHLY: 60,
+  TRIMONTHLY: 90,
+};
+
+export type OpenGymTierConfig = {
+  renewalPeriod: OpenGymRenewalPeriod;
+  label: string;
+  days: number;
+  defaultName: (branchName: string) => string;
+};
+
+export const OPEN_GYM_TIERS: OpenGymTierConfig[] = [
+  {
+    renewalPeriod: "WEEKLY",
+    label: "1 week",
+    days: 7,
+    defaultName: (branch) => `Open Gym Weekly — ${branch}`,
+  },
+  {
+    renewalPeriod: "BIWEEKLY",
+    label: "2 weeks",
+    days: 14,
+    defaultName: (branch) => `Open Gym 2 Weeks — ${branch}`,
+  },
+  {
+    renewalPeriod: "TRIWEEKLY",
+    label: "3 weeks",
+    days: 21,
+    defaultName: (branch) => `Open Gym 3 Weeks — ${branch}`,
+  },
+  {
+    renewalPeriod: "MONTHLY",
+    label: "1 month",
+    days: 30,
+    defaultName: (branch) => `Open Gym Monthly — ${branch}`,
+  },
+  {
+    renewalPeriod: "BIMONTHLY",
+    label: "2 months",
+    days: 60,
+    defaultName: (branch) => `Open Gym 2 Months — ${branch}`,
+  },
+  {
+    renewalPeriod: "TRIMONTHLY",
+    label: "3 months",
+    days: 90,
+    defaultName: (branch) => `Open Gym 3 Months — ${branch}`,
+  },
+];
+
+export const OPEN_GYM_RENEWAL_LABELS: Record<OpenGymRenewalPeriod, string> = {
+  WEEKLY: "Weekly",
+  BIWEEKLY: "2-Week",
+  TRIWEEKLY: "3-Week",
+  MONTHLY: "Monthly",
+  BIMONTHLY: "2-Month",
+  TRIMONTHLY: "3-Month",
+};
+
+export function formatRenewalPeriodLabel(
+  renewalPeriod?: OpenGymRenewalPeriod,
+  expiryPeriod?: string | number,
+): string {
+  if (renewalPeriod && OPEN_GYM_RENEWAL_LABELS[renewalPeriod]) {
+    return OPEN_GYM_RENEWAL_LABELS[renewalPeriod];
+  }
+  const days = Number(expiryPeriod);
+  if (days === 7) return "Weekly";
+  if (days === 14) return "2-Week";
+  if (days === 21) return "3-Week";
+  if (days === 30) return "Monthly";
+  if (days === 60) return "2-Month";
+  if (days === 90) return "3-Month";
+  if (days > 0) return `${days} days`;
+  return "Custom";
+}
